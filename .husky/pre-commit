# Block direct commits on main and develop (merges allowed)
# Exception: vibe-stack template repo itself (no gitflow needed)
project_name=$(grep -o '"name": *"[^"]*"' .flow/project.json 2>/dev/null | cut -d'"' -f4)
if [ "$project_name" != "vibe-stack" ]; then
  branch=$(git branch --show-current)
  if [ "$branch" = "main" ] || [ "$branch" = "develop" ]; then
    if [ ! -f .git/MERGE_HEAD ]; then
      echo ""
      echo "Commits directs sur '$branch' interdits."
      echo "Creer une branche feature/ ou fix/ depuis develop (ou hotfix/ depuis main)."
      echo "Utiliser un worktree : git worktree add .worktrees/feature-name develop"
      echo ""
      exit 1
    fi
  fi
fi

bunx lint-staged
